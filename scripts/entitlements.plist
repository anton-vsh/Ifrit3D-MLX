<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened-runtime entitlements for a Developer ID (non-App-Store)
         build. Not using App Sandbox — sandboxing a heavy ML runtime with
         arbitrary filesystem/network needs is its own large project and
         isn't required for direct distribution outside the App Store. -->

    <!-- PyTorch/MLX allocate and execute unsigned code pages (JIT'd Metal
         kernels, torch's own dynamic codegen paths). -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Bundled third-party dylibs (torch, mlx, etc.) aren't signed by this
         app's Team ID — hardened runtime blocks loading them without this. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Hugging Face model downloads. -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
