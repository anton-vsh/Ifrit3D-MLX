+    /// Sums `kernelSize` consecutive columns of a [H,W] array (edge-replicate padded).
+    /// Used as one pass of a separable box filter (see `depthEdgeReliability`).
+    private static func boxSumCols(_ a: MLXArray, kernelSize: Int) -> MLXArray {
