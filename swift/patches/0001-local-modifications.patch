+    /// Per-view seam-reliability field, port of mesh_render.py's Canny-based
+    /// `render_sketch_from_depth` + soft-taper (see `back_project`): OpenCV's
+    /// Canny isn't available in MLX, so depth discontinuities are found via a
+    /// simple gradient-magnitude threshold instead of true hysteresis edge
+    /// detection — a reasonable proxy for the same purpose (flagging depth
+    /// jumps at silhouette/crease edges, not tracing thin continuous lines).
+    /// The binary edge map is then box-filtered exactly like the Python
+    /// reference (separable sum over a `kernelSize`x`kernelSize` window,
+    /// divided by `kernelSize` — not squared — so reliability saturates to 0
+    /// once roughly one edge-line's worth of pixels falls in the window,
+    /// rather than requiring the whole window to be edge). Without this, a
+    /// view's blend weight can drop to zero abruptly right at a geometric
+    /// discontinuity (nose bridge, jaw edge), forcing the per-texel blend to
+    /// lean entirely on a different, independently-generated view right at
+    /// that edge — a visible hard seam with a lighting/color mismatch, worst
+    /// on high-curvature features.
+    private static func depthEdgeReliability(depthMap: MLXArray, covd: MLXArray, H: Int, Wd: Int) -> MLXArray {
+        let kernelSize = max(1, Int((2.0 / 512.0) * Float(max(H, Wd)))) * 2 + 1
+        let depth2d = depthMap.reshaped([H, Wd])
+        let cov2d = covd.reshaped([H, Wd]).asType(.float32)
+        let bigPos = MLXArray(Float(1e9)), bigNeg = MLXArray(Float(-1e9))
+        let dmax = MLX.where(cov2d .> 0, depth2d, bigNeg).max()
+        let dmin = MLX.where(cov2d .> 0, depth2d, bigPos).min()
+        let denom = MLX.maximum(dmax - dmin, MLXArray(Float(1e-6)))
+        let depthNorm = clip((depth2d - dmin) / denom, min: 0, max: 1) * cov2d
+
+        let Wd_ = Wd, H_ = H
+        let rightShift = concatenated([depthNorm[0..., 1..<Wd_], depthNorm[0..., (Wd_ - 1)..<Wd_]], axis: 1)
+        let dx = rightShift - depthNorm
+        let downShift = concatenated([depthNorm[1..<H_, 0...], depthNorm[(H_ - 1)..<H_, 0...]], axis: 0)
+        let dy = downShift - depthNorm
+        let gradMag = sqrt(dx * dx + dy * dy)
+        let edgeThreshold: Float = 0.06
+        let edge = (gradMag .> edgeThreshold).asType(.float32)
+
+        let dilated = boxSumRows(boxSumCols(edge, kernelSize: kernelSize), kernelSize: kernelSize)
+        let reliability = 1.0 - clip(dilated / Float(kernelSize), min: 0, max: 1)
+        return reliability.reshaped([H * Wd])
